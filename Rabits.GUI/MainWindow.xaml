<Window x:Class="Rabits.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rabits — Red Team Toolkit" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        TextOptions.TextFormattingMode="Ideal">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==== Top command bar ==== -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="18,12">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="🐇" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="RABITS" FontWeight="Bold" FontSize="16" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="RED TEAM TOOLKIT" Style="{StaticResource Caption}" Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ScopeInScope}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ScopeStatus}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==== Body: navigation rail + content ==== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="NAVIGATION" Style="{StaticResource Caption}"
                               Margin="18,16,0,8"/>
                    <ListBox Style="{StaticResource NavList}" ItemContainerStyle="{StaticResource NavItem}"
                             ItemsSource="{Binding NavItems}" SelectedItem="{Binding SelectedNav, Mode=TwoWay}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Glyph}" FontSize="15" Width="26" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="13.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentContent}"/>
        </Grid>

        <!-- ==== Status bar ==== -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="18,6">
            <Grid>
                <TextBlock HorizontalAlignment="Left" Style="{StaticResource Caption}">
                    <Run Text="Operator:"/>
                    <Run Text="{Binding OperatorName, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource Caption}"
                           Text="{Binding ScopeStatus}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
