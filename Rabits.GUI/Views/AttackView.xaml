<UserControl x:Class="Rabits.GUI.Views.AttackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rabits.GUI.Converters">
    <UserControl.Resources>
        <conv:AuthResultToBrushConverter x:Key="ResultBrush"/>
        <conv:BoolInverter x:Key="Not"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Field" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="Tile" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="TileValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Attacks / Credential Audit" Style="{StaticResource H1}"/>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Config panel -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="14" Margin="0,14,0,14"
                IsEnabled="{Binding IsRunning, Converter={StaticResource Not}}">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TARGET LOGIN URL" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Width="140">
                        <TextBlock Text="PROTOCOL" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Protocols}" SelectedItem="{Binding Protocol}"
                                  Margin="0,0,10,0" Padding="8,6" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="USERNAME" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Margin="0" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="USER FIELD" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding UserField, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="PASSWORD FIELD" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding PasswordField, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SUCCESS STATUS (e.g. 302)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding SuccessStatus, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="FAILURE CONTAINS" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Margin="0" Text="{Binding FailureContains, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="WORDLIST PATH (blank = embedded common list)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Text="{Binding WordlistPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Content="Stop on success" Foreground="{StaticResource TextBrush}"
                              VerticalAlignment="Bottom" Margin="0,0,16,8" IsChecked="{Binding StopOnSuccess}"/>
                    <StackPanel Grid.Column="2" Width="90" Margin="0,0,10,0">
                        <TextBlock Text="CONCURRENCY" Style="{StaticResource FieldLabel}"/>
                        <TextBox Style="{StaticResource Field}" Margin="0" Text="{Binding Concurrency, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Controls + stat tiles -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="▶  Run audit" Height="40" Margin="0,0,8,0" Command="{Binding StartCommand}"/>
            <Button Grid.Column="1" Content="■  Stop" Height="40" Background="#F85149" Margin="0,0,16,0" Command="{Binding StopCommand}"/>

            <Border Grid.Column="3" Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="ATTEMPTED" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Attempted, StringFormat=N0}" Style="{StaticResource TileValue}"/></StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="FAILURES" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Failures, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#6E7681"/></StackPanel>
            </Border>
            <Border Grid.Column="5" Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="ERRORS" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Errors, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#F85149"/></StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource Tile}" Margin="0">
                <StackPanel><TextBlock Text="FOUND" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Found, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#3FFF7A"/></StackPanel>
            </Border>
        </Grid>

        <!-- Results grid -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Results}" Margin="4" CanUserSortColumns="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Result" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Result}" FontWeight="Bold" VerticalAlignment="Center"
                                           Foreground="{Binding Result, Converter={StaticResource ResultBrush}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Username" Binding="{Binding Credential.Username}" Width="160">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Password" Binding="{Binding Credential.Password}" Width="200">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="80"/>
                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
