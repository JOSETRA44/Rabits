<UserControl x:Class="Rabits.GUI.Views.DynamicAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rabits.GUI.Converters"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <conv:SeverityToBrushConverter x:Key="SevBrush"/>
        <conv:ScopeFlagToBrushConverter x:Key="ScopeBrush"/>
        <Style x:Key="Tile" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="TileValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="MonoCol" TargetType="TextBlock" BasedOn="{StaticResource Mono}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Dynamic Recon — Interactive Layer-7 Analysis" Style="{StaticResource H1}"/>
            <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0"
                       Text="Browse the target; Rabits captures network events and hunts secrets in downloaded scripts, live."/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="360"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.1*" MinWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- Embedded browser -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="6">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="4,4,4,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,6"
                                 FontFamily="{StaticResource MonoFont}" CaretBrush="{StaticResource TextBrush}"
                                 KeyDown="OnAddressKeyDown"/>
                        <Button Grid.Column="1" Content="Go" Margin="8,0,8,0" Command="{Binding NavigateCommand}"/>
                        <Button Grid.Column="2" Content="Clear" Background="#30363D" Command="{Binding ClearCommand}"/>
                    </Grid>
                    <wv2:WebView2 x:Name="Browser"/>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- Live analysis -->
            <DockPanel Grid.Column="2">
                <UniformGrid DockPanel.Dock="Top" Rows="1" Columns="3" Margin="0,0,0,12">
                    <Border Style="{StaticResource Tile}">
                        <StackPanel><TextBlock Text="REQUESTS" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding TotalRequests, StringFormat=N0}" Style="{StaticResource TileValue}"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource Tile}">
                        <StackPanel><TextBlock Text="API ENDPOINTS" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding ApiCount, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#2F81F7"/></StackPanel>
                    </Border>
                    <Border Style="{StaticResource Tile}" Margin="0">
                        <StackPanel><TextBlock Text="SECRETS" Style="{StaticResource Caption}"/>
                            <TextBlock Text="{Binding SecretCount, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#F85149"/></StackPanel>
                    </Border>
                </UniformGrid>

                <Border Background="{StaticResource PanelBrush}" CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <TabControl Background="Transparent" BorderThickness="0" Margin="4">
                        <TabItem Header="Requests">
                            <DataGrid ItemsSource="{Binding Exchanges}" Margin="2" CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80"/>
                                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="70"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusCode}" Width="60"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                                    <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="160">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCol}">
                                                <Setter Property="Foreground" Value="{Binding InScope, Converter={StaticResource ScopeBrush}}"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="API Endpoints">
                            <DataGrid ItemsSource="{Binding ApiEndpoints}" Margin="2" CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="80"/>
                                    <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="180"/>
                                    <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCol}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Secrets">
                            <DataGrid ItemsSource="{Binding Secrets}" Margin="2" CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Severity" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Severity}" FontWeight="Bold" VerticalAlignment="Center"
                                                           Foreground="{Binding Severity, Converter={StaticResource SevBrush}}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Rule" Binding="{Binding RuleName}" Width="180"/>
                                    <DataGridTextColumn Header="Match" Binding="{Binding RedactedMatch}" Width="200">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCol}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Border>
            </DockPanel>
        </Grid>
    </Grid>
</UserControl>
