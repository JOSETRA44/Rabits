<UserControl x:Class="Rabits.GUI.Views.HostsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rabits.GUI.Converters">
    <UserControl.Resources>
        <conv:StatusToBrushConverter x:Key="StatusBrush"/>
        <Style x:Key="MonoCellHosts" TargetType="TextBlock" BasedOn="{StaticResource Mono}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==== Header ==== -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Host Discovery &amp; Network Map" Style="{StaticResource H1}"/>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- ==== Toolbar ==== -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,14,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="TARGET (CIDR OR IP)" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,6"
                             FontFamily="{StaticResource MonoFont}" CaretBrush="{StaticResource TextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="PORTS" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                    <ComboBox Width="130" ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                              Padding="8,6" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Grid.Column="2" Content="⟳  Discover" VerticalAlignment="Bottom" Height="34"
                        Command="{Binding DiscoverCommand}"/>
            </Grid>
        </Border>

        <!-- ==== Results grid ==== -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Hosts}" SelectedItem="{Binding SelectedHost, Mode=TwoWay}"
                      Margin="4" CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="IP" Binding="{Binding Ip}" SortMemberPath="IpSortKey" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCellHosts}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Status" Width="110" SortMemberPath="IsUp">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                             Fill="{Binding IsUp, Converter={StaticResource StatusBrush}}"/>
                                    <TextBlock Text="{Binding StatusText}" Margin="7,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Method}" Style="{StaticResource Caption}"
                                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="MAC" Binding="{Binding Mac}" SortMemberPath="Mac" Width="170">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MonoCellHosts}"/>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" SortMemberPath="Vendor" Width="*"/>
                    <DataGridTextColumn Header="Latency" Binding="{Binding LatencyText}" SortMemberPath="LatencyMs" Width="90"/>
                    <DataGridTextColumn Header="Open ports" Binding="{Binding OpenPortsText}" SortMemberPath="OpenPortsCount" Width="220"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
