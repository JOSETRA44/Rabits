<UserControl x:Class="Rabits.GUI.Views.TrafficView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rabits.GUI.Converters">
    <UserControl.Resources>
        <conv:TrafficProtocolToBrushConverter x:Key="ProtoBrush"/>

        <!-- A compact stat tile -->
        <Style x:Key="Tile" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
        <Style x:Key="TileValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Live Traffic Capture" Style="{StaticResource H1}"/>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,14,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="INTERFACE" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                              IsEnabled="{Binding IsCapturing, Converter={x:Static conv:BoolInverter.Instance}}"
                              Padding="8,6" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Width="200" Margin="0,0,12,0">
                    <TextBlock Text="BPF FILTER" Style="{StaticResource Caption}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                             Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,6"
                             FontFamily="{StaticResource MonoFont}" CaretBrush="{StaticResource TextBrush}"/>
                </StackPanel>

                <Button Grid.Column="2" Content="▶  Start" VerticalAlignment="Bottom" Height="34" Margin="0,0,8,0"
                        Command="{Binding StartCommand}"/>
                <Button Grid.Column="3" Content="■  Stop" VerticalAlignment="Bottom" Height="34"
                        Background="#F85149" Command="{Binding StopCommand}"/>
            </Grid>
        </Border>

        <!-- Stat tiles -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="8" Margin="0,0,0,14">
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="PACKETS" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding TotalPackets, StringFormat=N0}" Style="{StaticResource TileValue}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="PKTS/SEC" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding PacketsPerSecond, StringFormat=N0}" Style="{StaticResource TileValue}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="BYTES" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding TotalBytes, StringFormat=N0}" Style="{StaticResource TileValue}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="TCP" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Tcp, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#3FB950"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="UDP" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Udp, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#D29922"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="DNS" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Dns, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#2F81F7"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}">
                <StackPanel><TextBlock Text="ICMP" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Icmp, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#DB61A2"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Tile}" Margin="0">
                <StackPanel><TextBlock Text="ARP" Style="{StaticResource Caption}"/>
                    <TextBlock Text="{Binding Arp, StringFormat=N0}" Style="{StaticResource TileValue}" Foreground="#8B949E"/></StackPanel>
            </Border>
        </UniformGrid>

        <!-- Packet grid (rolling, capped) -->
        <Border Grid.Row="3" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Packets}" Margin="4" CanUserSortColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Proto" Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Protocol}" FontWeight="SemiBold" VerticalAlignment="Center"
                                           Foreground="{Binding Protocol, Converter={StaticResource ProtoBrush}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Source" Binding="{Binding SourceEndpoint}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Destination" Binding="{Binding DestinationEndpoint}" Width="180">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="70"/>
                    <DataGridTextColumn Header="Info" Binding="{Binding Info}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
