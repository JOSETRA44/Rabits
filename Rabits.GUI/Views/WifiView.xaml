<UserControl x:Class="Rabits.GUI.Views.WifiView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Rabits.GUI.Converters"
             xmlns:net="clr-namespace:Rabits.Domain.Networking;assembly=Rabits.Domain">
    <UserControl.Resources>
        <conv:EncryptionToBrushConverter x:Key="EncBrush"/>
        <conv:QualityToBrushConverter x:Key="QualBrush"/>
        <conv:BandToTextConverter x:Key="BandText"/>
        <Style x:Key="MonoCell" TargetType="TextBlock" BasedOn="{StaticResource Mono}">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ==== Main column: header + table ==== -->
        <DockPanel Grid.Column="0" Margin="0,0,16,0">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Text="Wireless Reconnaissance" Style="{StaticResource H1}"/>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource Caption}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button Content="⟳  Scan" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Command="{Binding ScanCommand}"/>
            </Grid>

            <Border Background="{StaticResource PanelBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <DataGrid ItemsSource="{Binding Networks}"
                          SelectedItem="{Binding SelectedNetwork, Mode=TwoWay}"
                          Margin="4">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="SSID" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplaySsid}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="BSSID" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Bssid}" Style="{StaticResource MonoCell}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Signal" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Rssi.Dbm, StringFormat={}{0} dBm}"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                                        <ProgressBar Value="{Binding Rssi.QualityPercent, Mode=OneWay}"
                                                     Maximum="100" Height="5" Margin="0,3,0,0"
                                                     Background="#0E1116" BorderThickness="0"
                                                     Foreground="{Binding Rssi.QualityPercent, Converter={StaticResource QualBrush}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Ch" Binding="{Binding Channel.Number}" Width="55"/>

                        <DataGridTextColumn Header="Band"
                                            Binding="{Binding Channel.Band, Converter={StaticResource BandText}}"
                                            Width="80"/>

                        <DataGridTemplateColumn Header="Encryption" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Left"
                                            Background="#12171F" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Encryption}" FontWeight="SemiBold" FontSize="11"
                                                   Foreground="{Binding Encryption, Converter={StaticResource EncBrush}}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </DockPanel>

        <!-- ==== Detail pane ==== -->
        <Border Grid.Column="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18"
                DataContext="{Binding SelectedNetwork}">
            <StackPanel>
                <TextBlock Text="DETAIL" Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding DisplaySsid}" Style="{StaticResource H1}" Margin="0,4,0,16"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Text="BSSID" Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding Bssid}" Style="{StaticResource Mono}" Margin="0,2,0,12"/>

                <TextBlock Text="Vendor OUI" Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding Bssid.Oui}" Style="{StaticResource Mono}" Margin="0,2,0,12"/>

                <TextBlock Text="Signal" Style="{StaticResource Caption}"/>
                <TextBlock Margin="0,2,0,12">
                    <Run Text="{Binding Rssi.Dbm, Mode=OneWay}" FontFamily="{StaticResource MonoFont}"/>
                    <Run Text=" dBm  ·  "/>
                    <Run Text="{Binding Rssi.QualityPercent, Mode=OneWay}"/>
                    <Run Text="% quality"/>
                </TextBlock>

                <TextBlock Text="Channel / Band" Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding Channel}" Margin="0,2,0,12"/>

                <TextBlock Text="Encryption" Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding Encryption}" FontWeight="SemiBold" Margin="0,2,0,12"
                           Foreground="{Binding Encryption, Converter={StaticResource EncBrush}}"/>

                <TextBlock Text="Capabilities" Style="{StaticResource Caption}"/>
                <TextBlock Text="{Binding Capabilities}" Style="{StaticResource Mono}" Margin="0,2,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
